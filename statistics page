const all      = dv.pages(`"${CONFIG.itemsFolder}"`).array();
const archived = all.filter(p => CONFIG.archiveStatuses.includes(lc(fk(p, "status"))));
const wishlist = all.filter(p => lc(fk(p, "status")) === CONFIG.wishlistStatus);
const active   = all.filter(p => !CONFIG.archiveStatuses.includes(lc(fk(p, "status")))
                               && lc(fk(p, "status")) !== CONFIG.wishlistStatus);

const totalCost     = active.reduce((s, p) => s + parseCost(fk(p, "cost")), 0);
const wishCost      = wishlist.reduce((s, p) => s + parseCost(fk(p, "cost")), 0);

const inRotation    = active.filter(p => CONFIG.activeStatuses.includes(lc(fk(p, "status"))));

