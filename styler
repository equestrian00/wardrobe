const allPages = dv.pages(`"${CONFIG.itemsFolder}"`).array();

function collectUnique(prop) {
    const s = new Set();
    allPages.forEach(p => asList(p[prop]).forEach(v => v && s.add(v)));
    return [...s].sort();
}

const ALL_SEASONS   = collectUnique(CONFIG.keys.season);
const ALL_MOODS     = collectUnique(CONFIG.keys.mood);
const ALL_OCCASIONS = collectUnique(CONFIG.keys.occasion);

const state = {
    heroPage:       null,
    filterSeason:   [],
    filterMood:     [],
    filterOccasion: [],
    filterFormula:  "Standard",
    wearableOnly:   true,
    debug:          CONFIG.debugDefault,
    slots:          {},
    requiredPaths:  new Set(),
};

// ═══════════════════════════════════════════════════════════════
//  🔁  SUGGESTION ENGINE
// ═══════════════════════════════════════════════════════════════

function updateSuggestions() {
    if (!state.heroPage) { state.slots = {}; return; }

    const formula  = OUTFIT_FORMULAS[state.filterFormula];
    const heroCat  = lc(fk(state.heroPage, "category"));
    const heroSub  = lc(fk(state.heroPage, "subcategory") || "");

    const skipCats = heroCat === "full body" ? ["tops", "bottoms", heroCat] : [heroCat];
    const needed   = formula.slots.filter(s => !skipCats.includes(s));

    state.slots = {};

    needed.forEach(slotCat => {
        let pool = allPages.filter(p => lc(fk(p, "category")) === slotCat);

        if (state.filterSeason.length) {
            const active = state.filterSeason.map(lc);
            pool = pool.filter(p =>
                asList(fk(p, "season")).some(s => active.includes(lc(s))));
        }
        if (state.filterMood.length) {
            const active = state.filterMood.map(lc);
            pool = pool.filter(p =>
                asList(fk(p, "mood")).some(m => active.includes(lc(m))));
        }
        if (state.filterOccasion.length) {
            const active = state.filterOccasion.map(lc);
            pool = pool.filter(p =>
                asList(fk(p, "occasion")).some(o => active.includes(lc(o))));
        }

        if (formula.seasons && formula.seasons.length) {
            const fSeasons = formula.seasons.map(lc);
            pool = pool.filter(p =>
                asList(fk(p, "season")).some(s => fSeasons.includes(lc(s))));
        }

        // ── Formula-level slot rules (subcategory + style restrictions) ──
        // Defined per-slot in the formulas note; applied before hero rules.
        const slotRule = formula.slotRules?.[slotCat];
        if (slotRule) {
            // Subcategory filter: hard restrict to listed subcategories
            if (slotRule.subcategories.length) {
                const allowed = slotRule.subcategories;
                const filtered = pool.filter(p =>
                    allowed.includes(lc(fk(p, "subcategory"))));
                if (filtered.length) pool = filtered;
            }
            // Style filter: prefer-if-available for each subcategory's styles
            if (Object.keys(slotRule.styles).length) {
                const styleFiltered = pool.filter(p => {
                    const pSub = lc(fk(p, "subcategory"));
                    const allowedStyles = slotRule.styles[pSub];
                    if (!allowedStyles || !allowedStyles.length) return true;
                    const pStyles = asList(fk(p, "style")).map(lc);
                    return pStyles.some(s => allowedStyles.includes(s));
                });
                if (styleFiltered.length) pool = styleFiltered;
            }
        }

        const subRule = CONFIG.SUBCATEGORY_RULES[heroSub];
        if (subRule && subRule[slotCat]) {
            const preferred = subRule[slotCat].map(lc);
            const prefPool  = pool.filter(p =>
                preferred.includes(lc(fk(p, "subcategory"))));
            if (prefPool.length > 0) pool = prefPool;
        }

        const scored = pool
            .map(p => scoreCandidate(state.heroPage, p, state.wearableOnly))
            .filter(Boolean)
            .sort((a, b) => b.score - a.score);

        state.slots[slotCat] = { candidates: scored, index: 0, locked: false };
    });

    resolveRequires();
}

function resolveRequires() {
    state.requiredPaths = new Set();
    if (!state.heroPage) return;

    Object.values(state.slots).forEach(s => { s.locked = false; });

    const visited = new Set([state.heroPage.file.path]);
    const queue   = [state.heroPage];

    while (queue.length) {
        const page     = queue.shift();
        const reqPaths = linkPaths(fk(page, "requires"));

        for (const rPath of reqPaths) {
            const reqPage = allPages.find(p => fileMatchesAny(p.file.path, [rPath]));
            if (!reqPage || visited.has(reqPage.file.path)) continue;
            visited.add(reqPage.file.path);

            state.requiredPaths.add(reqPage.file.path);
            const cat = lc(fk(reqPage, "category"));

            if (!state.slots[cat]) {
                state.slots[cat] = { candidates: [], index: 0, locked: false };
            }

            const slot = state.slots[cat];
            slot.candidates = slot.candidates.filter(
                c => c.page.file.path !== reqPage.file.path
            );
            slot.candidates.unshift({ page: reqPage, score: 999, reasons: ["required"] });
            slot.index  = 0;
            slot.locked = true;

            queue.push(reqPage);
        }
    }
}

function pickRandomHero() {
    let pool = allPages;
    if (state.wearableOnly) {
        pool = pool.filter(p => {
            const s = lc(fk(p, "status"));
            return s !== "hamper" && s !== "laundry" &&
                   s !== "donate" && s !== "repair";
        });
    }
    if (state.filterSeason.length) {
        const active = state.filterSeason.map(lc);
        pool = pool.filter(p =>
            asList(fk(p, "season")).some(s => active.includes(lc(s))));
    }
    if (state.filterMood.length) {
        const active = state.filterMood.map(lc);
        pool = pool.filter(p =>
            asList(fk(p, "mood")).some(m => active.includes(lc(m))));
    }
    if (state.filterOccasion.length) {
        const active = state.filterOccasion.map(lc);
        pool = pool.filter(p =>
            asList(fk(p, "occasion")).some(o => active.includes(lc(o))));
    }
    if (!pool.length) { showToast("No items match the active filters."); return; }
    state.heroPage = pool[Math.floor(Math.random() * pool.length)];
    updateSuggestions();
}

