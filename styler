//  🔧  DOM MICRO-HELPERS
// ═══════════════════════════════════════════════════════════════

function make(tag, cls = "") {
    const el = document.createElement(tag);
    if (cls) el.className = cls;
    return el;
}

function makeBtn(text, cls, onClick) {
    const btn = make("button", cls);
    btn.textContent = text;
    btn.onclick = onClick;
    return btn;
}

