// ═══════════════════════════════════════════════════════════════
//  🛠  UTILITY HELPERS
// ═══════════════════════════════════════════════════════════════

/** Coerce a frontmatter value to a clean string array */
function asList(val) {
    if (!val) return [];
    if (Array.isArray(val)) return val.map(v => String(v).trim()).filter(Boolean);
    return [String(val).trim()].filter(Boolean);
}

/** Lowercase + trim a single value */
function lc(v) { return String(v || "").toLowerCase().trim(); }

/** Display name: "Brand Style Subcategory" */
function displayName(p) {
    return [p.brand, p.clothingstyle, p.clothingsubcategory]
        .filter(Boolean).map(s => String(s).trim()).join(" ") || p.file.name.replace(/\.md$/, "");
}

/** Resolve an image frontmatter value to a usable src URL */
function resolveImage(imageProp) {
    if (!imageProp) return null;
    const s = String(imageProp);
    // Wikilink  ![[file.jpg]]  or  [[file.jpg]]
    const wm = s.match(/!?\[\[(.+?)(?:\|[^\]]+)?\]\]/);
    if (wm) {
        const name = wm[1];
        const f = app.vault.getFiles().find(
            fi => fi.name === name || fi.path === name ||
                  fi.path.endsWith("/" + name)
        );
        return f ? app.vault.getResourcePath(f) : null;
    }
    if (/^https?:\/\//.test(s)) return s;
    // Plain path
    const f2 = app.vault.getAbstractFileByPath(s);
    return f2 ? app.vault.getResourcePath(f2) : null;
}

/**
 * Extract file paths from a frontmatter link property.
 * DataviewJS returns Link objects with a .path; we also handle
 * plain strings and wikilink strings.
 */
function linkPaths(val) {
    if (!val) return [];
    const arr = Array.isArray(val) ? val : [val];
    return arr.map(l => {
        if (l && typeof l === "object" && l.path) return l.path;
        const s = String(l);
        const m = s.match(/\[\[(.+?)(?:\|[^\]]+)?\]\]/);
        return m ? m[1] : s;
    }).filter(Boolean);
}

/** True if filePath matches any path in a link-paths array */
function fileMatchesAny(filePath, paths) {
    const base = filePath.replace(/\.md$/, "");
    return paths.some(p => {
        const pb = p.replace(/\.md$/, "");
        return filePath === p || base === pb ||
               filePath === p + ".md" ||
               filePath.endsWith("/" + p) ||
               filePath.endsWith("/" + p + ".md");
    });
}

/** Count overlapping items (case-insensitive) between two string arrays */
function countOverlap(a, b) {
    const bSet = new Set(b.map(lc));
    return a.filter(x => bSet.has(lc(x))).length;
}

/** Color-theory match: does any heroColor pair well with any candidateColor? */
function colorTheoryMatch(heroColors, candColors, theory) {
    for (const hc of heroColors) {
        const allowed = (theory[hc] || []).map(lc);
        if (candColors.some(cc => allowed.includes(lc(cc)))) return true;
    }
    return false;
}

// ═══════════════════════════════════════════════════════════════
//  🧠  SCORING ENGINE
// ═══════════════════════════════════════════════════════════════

/**
 * Score a candidate against the hero item.
 * Returns null if the candidate fails any hard filter,
 * or { page, score, reasons[] } otherwise.
 */
function scoreCandidate(hero, candidate, wearableOnly) {
    // Skip self
    if (candidate.file.path === hero.file.path) return null;

    // ── Hard filter: wearable status ──
    if (wearableOnly) {
        const s = lc(candidate.clothingstatus);
        if (s === "hamper" || s === "laundry" ||
            s === "donate"  || s === "repair") return null;
    }

    // ── Hard filter: avoids ──
    const heroAvoids = linkPaths(hero.avoids);
    const candAvoids = linkPaths(candidate.avoids);
    if (fileMatchesAny(candidate.file.path, heroAvoids)) return null;
    if (fileMatchesAny(hero.file.path, candAvoids))      return null;

    // ── Scoring ──
    let score = 0;
    const reasons = [];

    // +100  explicit pair
    const heroPairs = linkPaths(hero.pairs);
    if (fileMatchesAny(candidate.file.path, heroPairs)) {
        score += CONFIG.SCORE.EXPLICIT_PAIR;
        reasons.push(`+${CONFIG.SCORE.EXPLICIT_PAIR} paired`);
    }

    // +50  color theory
    const hColors = asList(hero.color);
    const cColors = asList(candidate.color);
    if (hColors.length && cColors.length &&
        colorTheoryMatch(hColors, cColors, CONFIG.COLOR_THEORY)) {
        score += CONFIG.SCORE.COLOR_MATCH;
        reasons.push(`+${CONFIG.SCORE.COLOR_MATCH} color`);
    }

    // +20 × n  mood overlap
    const moodHits = countOverlap(asList(hero.mood), asList(candidate.mood));
    if (moodHits) {
        const pts = moodHits * CONFIG.SCORE.MOOD_OVERLAP;
        score += pts;
        reasons.push(`+${pts} mood`);
    }

    // +20 × n  occasion overlap
    const occHits = countOverlap(asList(hero.occasion), asList(candidate.occasion));
    if (occHits) {
        const pts = occHits * CONFIG.SCORE.OCCASION_OVERLAP;
        score += pts;
        reasons.push(`+${pts} occasion`);
    }

    // +15 × n  season overlap
    const seasonHits = countOverlap(asList(hero.season), asList(candidate.season));
    if (seasonHits) {
        const pts = seasonHits * CONFIG.SCORE.SEASON_OVERLAP;
        score += pts;
        reasons.push(`+${pts} season`);
    }

    return { page: candidate, score, reasons };
}

// ═══════════════════════════════════════════════════════════════
//  📦  STATE
// ═══════════════════════════════════════════════════════════════

const allPages = dv.pages(`"${CONFIG.itemsFolder}"`).array();

function collectUnique(prop) {
    const s = new Set();
    allPages.forEach(p => asList(p[prop]).forEach(v => v && s.add(v)));
    return [...s].sort();
}

const ALL_SEASONS   = collectUnique("season");
const ALL_MOODS     = collectUnique("mood");
const ALL_OCCASIONS = collectUnique("occasion");

const state = {
    heroPage:       null,
    filterSeason:   [],
    filterMood:     [],
    filterOccasion: [],
    filterFormula:  "Standard",
    wearableOnly:   true,
    debug:          CONFIG.debugDefault,
    // slots: { categoryKey -> { candidates: ScoredItem[], index: number, locked: bool } }
    slots: {},
    // Paths of items forced in by a `requires` link (used for badge + lock)
    requiredPaths:  new Set(),
};

// ═══════════════════════════════════════════════════════════════
//  🔁  SUGGESTION ENGINE
// ═══════════════════════════════════════════════════════════════

function updateSuggestions() {
    if (!state.heroPage) { state.slots = {}; return; }

    const formula  = CONFIG.OUTFIT_FORMULAS[state.filterFormula];
    const heroCat  = lc(state.heroPage.clothingcategory);
    const heroSub  = lc(state.heroPage.clothingsubcategory || "");

    // Slots the formula needs, minus the hero's own category
    const skipCats = heroCat === "full body" ? ["tops", "bottoms", heroCat] : [heroCat];
    const needed   = formula.slots.filter(s => !skipCats.includes(s));

    state.slots = {};

    needed.forEach(slotCat => {
        // Base pool: correct category
        let pool = allPages.filter(p => lc(p.clothingcategory) === slotCat);

        // Apply global season / mood / occasion filters to suggestion pool
        if (state.filterSeason.length) {
            const active = state.filterSeason.map(lc);
            pool = pool.filter(p =>
                asList(p.season).some(s => active.includes(lc(s))));
        }
        if (state.filterMood.length) {
            const active = state.filterMood.map(lc);
            pool = pool.filter(p =>
                asList(p.mood).some(m => active.includes(lc(m))));
        }
        if (state.filterOccasion.length) {
            const active = state.filterOccasion.map(lc);
            pool = pool.filter(p =>
                asList(p.occasion).some(o => active.includes(lc(o))));
        }

        // Formula-level season restriction
        if (formula.seasons && formula.seasons.length) {
            const fSeasons = formula.seasons.map(lc);
            pool = pool.filter(p =>
                asList(p.season).some(s => fSeasons.includes(lc(s))));
        }

        // Subcategory preference override
        const subRule = CONFIG.SUBCATEGORY_RULES[heroSub];
        if (subRule && subRule[slotCat]) {
            const preferred = subRule[slotCat].map(lc);
            const prefPool  = pool.filter(p =>
                preferred.includes(lc(p.clothingsubcategory)));
            if (prefPool.length > 0) pool = prefPool;
        }

        // Score every candidate
        const scored = pool
            .map(p => scoreCandidate(state.heroPage, p, state.wearableOnly))
            .filter(Boolean)
            .sort((a, b) => b.score - a.score);

        state.slots[slotCat] = { candidates: scored, index: 0, locked: false };
    });

    // ── Resolve `requires` links (cascading) ──────────────────────
    resolveRequires();
}

/**
 * After scoring is done, walk every active item's `requires` links and
 * force those pages to the front of their category slot.
 *
 * • If the slot already exists: required item is moved to index 0 and
 *   the slot is locked (shuffle hidden) so it can't be cycled away from.
 * • If the slot doesn't exist yet (category not in the formula): a new
 *   slot is created so the item always shows up.
 * • Cascades: if a required item itself has `requires`, those are
 *   resolved too — loops until no new items are discovered.
 */
function resolveRequires() {
    state.requiredPaths = new Set();
    if (!state.heroPage) return;

    // Unlock all slots before re-resolving (clean slate each call)
    Object.values(state.slots).forEach(s => { s.locked = false; });

    // BFS from hero, then cascade through each required item
    const visited = new Set([state.heroPage.file.path]);
    const queue   = [state.heroPage];

    while (queue.length) {
        const page    = queue.shift();
        const reqPaths = linkPaths(page.requires);

        for (const rPath of reqPaths) {
            // Find the page in the vault
            const reqPage = allPages.find(p => fileMatchesAny(p.file.path, [rPath]));
            if (!reqPage || visited.has(reqPage.file.path)) continue;
            visited.add(reqPage.file.path);

            state.requiredPaths.add(reqPage.file.path);
            const cat = lc(reqPage.clothingcategory);

            // Create slot if the formula didn't include this category
            if (!state.slots[cat]) {
                state.slots[cat] = { candidates: [], index: 0, locked: false };
            }

            const slot = state.slots[cat];

            // Remove it from wherever it already sits in the candidate list
            slot.candidates = slot.candidates.filter(
                c => c.page.file.path !== reqPage.file.path
            );

            // Push to the very front with a sentinel score
            slot.candidates.unshift({
                page:    reqPage,
                score:   999,
                reasons: ["required"],
            });

            // Lock: index snaps to 0 and the shuffle button is hidden
            slot.index  = 0;
            slot.locked = true;

            // Cascade into this item's own requires
            queue.push(reqPage);
        }
    }
}

function pickRandomHero() {
    let pool = allPages;
    if (state.wearableOnly) {
        pool = pool.filter(p => {
            const s = lc(p.clothingstatus);
            return s !== "hamper" && s !== "laundry" &&
                   s !== "donate" && s !== "repair";
        });
    }
    if (state.filterSeason.length) {
        const active = state.filterSeason.map(lc);
        pool = pool.filter(p =>
            asList(p.season).some(s => active.includes(lc(s))));
    }
    if (state.filterMood.length) {
        const active = state.filterMood.map(lc);
        pool = pool.filter(p =>
            asList(p.mood).some(m => active.includes(lc(m))));
    }
    if (state.filterOccasion.length) {
        const active = state.filterOccasion.map(lc);
        pool = pool.filter(p =>
            asList(p.occasion).some(o => active.includes(lc(o))));
    }
    if (!pool.length) { showToast("⚠ No items match the active filters."); return; }
    state.heroPage = pool[Math.floor(Math.random() * pool.length)];
    updateSuggestions();
}

// ═══════════════════════════════════════════════════════════════
//  📋  LOG OUTFIT
// ═══════════════════════════════════════════════════════════════

async function logOutfit() {
    if (!state.heroPage) return;

    const formula  = CONFIG.OUTFIT_FORMULAS[state.filterFormula];
    const heroCat  = lc(state.heroPage.clothingcategory);
    const skipCats = heroCat === "full body" ? ["tops", "bottoms", heroCat] : [heroCat];
    const activeSlots = formula.slots.filter(s => !skipCats.includes(s));

    const outfitPages = activeSlots
        .map(slotCat => {
            const d = state.slots[slotCat];
            if (!d || !d.candidates.length) return null;
            return d.candidates[d.index % d.candidates.length].page;
        })
        .filter(Boolean);

    const today      = new Date().toLocaleDateString("en-CA"); // YYYY-MM-DD
    const allInFit   = [state.heroPage, ...outfitPages];

    try {
        for (const page of allInFit) {
            const others = allInFit
                .filter(p => p.file.path !== page.file.path)
                .map(p => `[[${p.file.name.replace(/\.md$/, "")}]]`)
                .join(", ");

            await app.fileManager.processFrontMatter(page.file, fm => {
                fm.wear_count = (parseInt(fm.wear_count) || 0) + 1;
                if (!fm.outfits) fm.outfits = [];
                if (!Array.isArray(fm.outfits)) fm.outfits = [fm.outfits];
                fm.outfits.push(`${today}: Worn with ${others}`);
            });
        }
        showToast(`✓ Outfit logged — ${allInFit.length} items updated.`);
    } catch (e) {
        showToast(`⚠ Could not log outfit: ${e.message}`, true);
        console.error("[Wardrobe Stylist] logOutfit error:", e);
    }
}

