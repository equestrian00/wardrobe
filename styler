let $canvas = null;

function render() {
    ROOT.innerHTML = "";
    $canvas = null;
    ROOT.appendChild(buildHeader());
    ROOT.appendChild(buildFilters());
    ROOT.appendChild(buildCanvas());
}

// ── Header ───────────────────────────────────────────────────────
function buildHeader() {
    const el = make("div", "ws-header");

    const title = make("span", "ws-header__wordmark");
    title.innerHTML = `<span class="ws-header__icon">✦</span> Wardrobe Stylist`;
    el.appendChild(title);

    const right = make("div", "ws-header__right");

    const wLabel = make("label", "ws-wearable-label");
    wLabel.title = "When on, only Clean items appear";

    const wCb = document.createElement("input");
    wCb.type    = "checkbox";
    wCb.checked = state.wearableOnly;
    wCb.style.display = "none";
    wCb.onchange = () => {
        state.wearableOnly = wCb.checked;
        updateSuggestions();
        refreshCanvas();
        dot.className = "ws-wearable-dot" + (state.wearableOnly ? " ws-wearable-dot--on" : "");
        wLabel.title  = state.wearableOnly
            ? "Wearable only (clean items)"
            : "All items (including laundry, etc.)";
    };

    const dot   = make("span", "ws-wearable-dot" + (state.wearableOnly ? " ws-wearable-dot--on" : ""));
    const wText = make("span", "ws-wearable-text");
    wText.textContent = "Wearable";

    wLabel.appendChild(wCb);
    wLabel.appendChild(dot);
    wLabel.appendChild(wText);
    right.appendChild(wLabel);

    const dLabel = make("label", "ws-debug-label");
    dLabel.title = "Show scoring breakdown on suggestion cards";
    const dCb = document.createElement("input");
    dCb.type    = "checkbox";
    dCb.checked = state.debug;
    dCb.style.display = "none";
    dCb.onchange = () => { state.debug = dCb.checked; render(); };
    const dText = make("span");
    dText.textContent = "Debug";
    dLabel.appendChild(dCb);
    dLabel.appendChild(dText);
    right.appendChild(dLabel);

    el.appendChild(right);
    return el;
}

// ── Filters ──────────────────────────────────────────────────────
function buildFilters() {
    const el = make("div", "ws-filters");

    if (ALL_SEASONS.length) {
        el.appendChild(buildPillGroup("Season", ALL_SEASONS, state.filterSeason, () => {
            updateSuggestions(); refreshCanvas();
        }));
    }
    if (ALL_MOODS.length) {
        el.appendChild(buildPillGroup("Mood", ALL_MOODS, state.filterMood, () => {
            updateSuggestions(); refreshCanvas();
        }));
    }
    if (ALL_OCCASIONS.length) {
        el.appendChild(buildPillGroup("Occasion", ALL_OCCASIONS, state.filterOccasion, () => {
            updateSuggestions(); refreshCanvas();
        }));
    }

    const formulaGroup = make("div", "ws-filter-group");
    const formulaLabel = make("span", "ws-filter-label");
    formulaLabel.textContent = "Formula";
    formulaGroup.appendChild(formulaLabel);

    const sel = make("select", "ws-select");
    Object.keys(CONFIG.OUTFIT_FORMULAS).forEach(name => {
        const opt = document.createElement("option");
        opt.value       = name;
        opt.textContent = name;
        opt.selected    = name === state.filterFormula;
        sel.appendChild(opt);
    });
    sel.onchange = () => {
        state.filterFormula = sel.value;
        updateSuggestions(); refreshCanvas();
    };
    formulaGroup.appendChild(sel);
    el.appendChild(formulaGroup);

    const rndBtn = makeBtn("Random", "ws-btn ws-btn--random", () => {
        pickRandomHero();
        render();
    });
    el.appendChild(rndBtn);

    return el;
}

function buildPillGroup(labelText, options, activeArr, onChange) {
    const group = make("div", "ws-filter-group ws-filter-group--pills");
    const lbl   = make("span", "ws-filter-label");
    lbl.textContent = labelText;
    group.appendChild(lbl);

    const pills = make("div", "ws-pills");
    options.forEach(opt => {
        const pill = make("button",
            "ws-pill" + (activeArr.map(lc).includes(lc(opt)) ? " ws-pill--on" : ""));
        pill.textContent = opt;
        pill.onclick = () => {
            const idx = activeArr.findIndex(x => lc(x) === lc(opt));
            if (idx >= 0) activeArr.splice(idx, 1);
            else          activeArr.push(opt);
            pill.classList.toggle("ws-pill--on", activeArr.map(lc).includes(lc(opt)));
            onChange();
        };
        pills.appendChild(pill);
    });

    group.appendChild(pills);
    return group;
}

// ── Canvas ────────────────────────────────────────────────────────
function buildCanvas() {
    $canvas = make("div", "ws-canvas");
    refreshCanvas();
    return $canvas;
}

function refreshCanvas() {
    if (!$canvas) return;
    $canvas.innerHTML = "";

    const heroPanel = make("div", "ws-panel ws-panel--hero");

    if (state.heroPage) {
        heroPanel.appendChild(buildCard(state.heroPage, null, null, true));
    } else {
        const placeholder = make("div", "ws-card-placeholder");
        placeholder.innerHTML = `<span class="ws-placeholder-icon">✦</span>
            <p class="ws-placeholder-text">Select a hero item below<br>or hit Random</p>`;
        heroPanel.appendChild(placeholder);
    }

    heroPanel.appendChild(buildHeroSelector());
    $canvas.appendChild(heroPanel);

    const suggPanel = make("div", "ws-panel ws-panel--suggestions");

    if (!state.heroPage) {
        const hint = make("p", "ws-hint");
        hint.textContent = "Your outfit will appear here once you pick a hero item.";
        suggPanel.appendChild(hint);
    } else {
        const formula     = CONFIG.OUTFIT_FORMULAS[state.filterFormula];
        const heroCat     = lc(fk(state.heroPage, "category"));
        const skipCats    = heroCat === "full body" ? ["tops", "bottoms", heroCat] : [heroCat];
        const activeSlots = formula.slots.filter(s => !skipCats.includes(s));

        if (!activeSlots.length) {
            const hint = make("p", "ws-hint");
            hint.textContent = "This item fills all formula slots — try a different formula.";
            suggPanel.appendChild(hint);
        } else {
            activeSlots.forEach(slotCat => {
                const slotData  = state.slots[slotCat];
                const slotWrap  = make("div", "ws-slot");
                const slotLabel = make("div", "ws-slot-label");
                slotLabel.textContent = slotCat;
                slotWrap.appendChild(slotLabel);

                if (!slotData || !slotData.candidates.length) {
                    const empty = make("div", "ws-slot-empty");
                    empty.textContent = `No ${slotCat} match`;
                    slotWrap.appendChild(empty);
                } else {
                    const total  = slotData.candidates.length;
                    const idx    = slotData.index % total;
                    const item   = slotData.candidates[idx];
                    const locked = slotData.locked;

                    slotWrap.appendChild(buildCard(
                        item.page, item.score, item.reasons, false,
                        locked ? null : () => { slotData.index++; refreshCanvas(); },
                        state.requiredPaths.has(item.page.file.path)
                    ));

                    if (total > 1 && !locked) {
                        const counter = make("div", "ws-slot-counter");
                        counter.textContent = `${idx + 1} / ${total}`;
                        slotWrap.appendChild(counter);
                    }
                }

                suggPanel.appendChild(slotWrap);
            });

            // Extra slots injected by requires resolution
            Object.keys(state.slots)
                .filter(cat => !activeSlots.includes(cat) && !skipCats.includes(cat))
                .forEach(slotCat => {
                    const slotData = state.slots[slotCat];
                    if (!slotData || !slotData.candidates.length) return;

                    const slotWrap  = make("div", "ws-slot");
                    const slotLabel = make("div", "ws-slot-label ws-slot-label--required");
                    slotLabel.textContent = slotCat;
                    slotLabel.title = "Added automatically by a requires rule";
                    slotWrap.appendChild(slotLabel);

                    const item = slotData.candidates[slotData.index % slotData.candidates.length];
                    slotWrap.appendChild(buildCard(item.page, item.score, item.reasons, false, null, true));
                    suggPanel.appendChild(slotWrap);
                });
        }   // end else (activeSlots exist)

        suggPanel.appendChild(makeBtn("Log Outfit", "ws-btn ws-btn--log", () => logOutfit()));
    }

    $canvas.appendChild(suggPanel);
}

// ── Hero Selector ────────────────────────────────────────────────
function buildHeroSelector() {
    const wrap = make("div", "ws-hero-selector");
    const sel  = make("select", "ws-select ws-select--hero");

    const ph = document.createElement("option");
    ph.value       = "";
    ph.textContent = state.heroPage ? "Change hero…" : "Select hero item…";
    sel.appendChild(ph);

    let heroPool = state.wearableOnly
        ? allPages.filter(p => {
              const s = lc(fk(p, "status"));
              return s !== "hamper" && s !== "laundry" &&
                     s !== "donate" && s !== "repair";
          })
        : allPages;

    const grouped = {};
    heroPool.forEach(p => {
        const cat = fk(p, "category") || "Uncategorized";
        (grouped[cat] = grouped[cat] || []).push(p);
    });

    Object.entries(grouped)
        .sort((a, b) => a[0].localeCompare(b[0]))
        .forEach(([cat, items]) => {
            const og = document.createElement("optgroup");
            og.label = cat;
            items
                .sort((a, b) => displayName(a).localeCompare(displayName(b)))
                .forEach(p => {
                    const opt = document.createElement("option");
                    opt.value       = p.file.path;
                    opt.textContent = displayName(p);
                    opt.selected    = !!(state.heroPage &&
                                         state.heroPage.file.path === p.file.path);
                    og.appendChild(opt);
                });
            sel.appendChild(og);
        });

    sel.onchange = () => {
        if (!sel.value) return;
        state.heroPage = allPages.find(p => p.file.path === sel.value) || null;
        updateSuggestions();
        render();
    };

    wrap.appendChild(sel);
    return wrap;
}

// ── Card ─────────────────────────────────────────────────────────
function buildCard(page, score, reasons, isHero, onShuffle, isRequired = false) {
    const imgSrc = resolveImage(fk(page, "image"));
    const name   = displayName(page);
    const size   = fk(page, "size")         ? `Size ${fk(page, "size")}` : "";
    const colors = asList(fk(page, "color")).join(", ");
    const tags   = asList(fk(page, "styling_tags")).join("  ·  ");

    const card = make("div", "ws-card" + (isHero ? " ws-card--hero" : ""));

    const imgEl = make("div", "ws-card__img");
    if (imgSrc) {
        imgEl.style.backgroundImage = `url('${imgSrc}')`;
    } else {
        imgEl.innerHTML = `<span class="ws-card__no-img">✦</span>`;
    }
    card.appendChild(imgEl);

    if (isRequired) {
        const reqBadge = make("div", "ws-required-badge");
        reqBadge.textContent = "✦ required";
        card.appendChild(reqBadge);
    } else if (!isHero && score !== undefined && state.debug) {
        const badge = make("div", "ws-score-badge");
        badge.textContent = score;
        if (reasons && reasons.length) badge.title = reasons.join("  |  ");
        card.appendChild(badge);
    }

    if (!isHero && onShuffle) {
        const shuffleBtn = make("button", "ws-shuffle-btn");
        shuffleBtn.textContent = "↻";
        shuffleBtn.title = "Swap for next match";
        shuffleBtn.onclick = e => { e.stopPropagation(); onShuffle(); };
        card.appendChild(shuffleBtn);
    }

    const info = make("div", "ws-card__info");

    const titleEl = make("div", "ws-card__title");
    titleEl.textContent = name;
    info.appendChild(titleEl);

    if (size || colors) {
        const meta = make("div", "ws-card__meta");
        meta.textContent = [size, colors].filter(Boolean).join("  ·  ");
        info.appendChild(meta);
    }

    if (tags) {
        const tagsEl = make("div", "ws-card__tags");
        tagsEl.textContent = tags;
        info.appendChild(tagsEl);
    }

    card.appendChild(info);
    return card;
}

