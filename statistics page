const ROOT = dv.container;
ROOT.className = "wst-root";

// ── 1. Summary strip ─────────────────────────────────────────
const summaryStrip = make("div", "wst-summary-strip");
[
    statCard("Total Items",     String(active.length)),
    statCard("Total Value",     fmt$(totalCost), `across ${active.length} items`),
    statCard("Avg Cost / Item", fmt$(active.length ? totalCost / active.length : 0)),
    statCard("Wishlist",        String(wishlist.length), `${fmt$(wishCost)} estimated`),
].forEach(c => summaryStrip.appendChild(c));
ROOT.appendChild(summaryStrip);

// ── 2. Top Colors & Seasons ───────────────────────────────────
const colorData  = tally(active, p => fk(p, "color"), true);
const seasonData = tally(active, p => fk(p, "season"), true);

const csRow = make("div", "wst-row");
csRow.appendChild(section("Top Colors", colorDonutChart(colorData, CONFIG.topN), { collapsible: false }));
csRow.appendChild(section("By Season",  seasonDonutChart(seasonData),             { collapsible: false }));
ROOT.appendChild(csRow);

// ── 3. Active vs Total — no header, not collapsible ───────────
const activeCount = inRotation.length;
const totalCount  = active.length;
const activeStrip = make("div", "wst-summary-strip wst-summary-strip--sub");
[
    statCard("In Rotation",  String(activeCount), "clean · hamper · laundry"),
    statCard("Sidelined",    String(totalCount - activeCount), "donate · repair · replace"),
    statCard("Archived",     String(archived.length), "donated · sold · trashed"),
].forEach(c => activeStrip.appendChild(c));
ROOT.appendChild(section(null, activeStrip, statusBar(active, totalCount)));

// ── 4. Items by Location — no header, not collapsible ─────────
const locationData = tally(
    active.filter(p => lc(fk(p, "location")) !== "archive"),
    p => fk(p, "location")
);
ROOT.appendChild(section(null, barChart(locationData, { showCount: true })));

// ── 5. Brands & Styling Tags — not collapsible ────────────────
const brandData = tally(active, p => fk(p, "brand"));
const tagData   = tally(active, p => fk(p, "styling_tags"), true);

const btRow = make("div", "wst-row");
btRow.appendChild(section(
    `Top ${CONFIG.topN} Brands`,
    barChart(brandData, { maxBars: CONFIG.topN, showCount: true })
));
btRow.appendChild(section(
    `Top ${CONFIG.topN} Styling Tags`,
    barChart(tagData, { maxBars: CONFIG.topN, showCount: true })
));
ROOT.appendChild(btRow);

// ── 6. By Category & Subcategory — collapsible, open ─────────
const catRow = make("div", "wst-row");
catRow.appendChild(section(
    "By Category",
    barChart(tally(active, p => fk(p, "category"))),
    { collapsed: true }
));
catRow.appendChild(section(
    "By Subcategory",
    barChart(tally(active, p => fk(p, "subcategory")), { maxBars: 12 }),
    { collapsed: true }
));
ROOT.appendChild(catRow);

// ── 7. Most & Least Versatile — collapsible, open ────────────
const byPairs  = linkCount(active, "pairs").slice(0, CONFIG.topN);
const byAvoids = linkCount(active, "avoids").slice(0, CONFIG.topN);

const mostVers = make("div", "wst-bars");
byPairs.filter(r => r.count > 0).forEach(({ page: p, count }) => {
    const row = make("div", "wst-bar-row");
    const name = [fk(p, "brand"), fk(p, "subcategory")].filter(Boolean).join(" ");
    row.appendChild(text("span", "wst-bar-label", name || p.file.name));
    const track = make("div", "wst-bar-track");
    const fill  = make("div", "wst-bar-fill");
    fill.style.width = pct(count, byPairs[0]?.count || 1) + "%";
    track.appendChild(fill);
    row.appendChild(track);
    row.appendChild(text("span", "wst-bar-value", `${count} pairs`));
    mostVers.appendChild(row);
});

const leastVers = make("div", "wst-bars");
byAvoids.filter(r => r.count > 0).forEach(({ page: p, count }) => {
    const row = make("div", "wst-bar-row");
    const name = [fk(p, "brand"), fk(p, "subcategory")].filter(Boolean).join(" ");
    row.appendChild(text("span", "wst-bar-label", name || p.file.name));
    const track = make("div", "wst-bar-track");
    const fill  = make("div", "wst-bar-fill wst-bar-fill--avoid");
    fill.style.width = pct(count, byAvoids[0]?.count || 1) + "%";
    track.appendChild(fill);
    row.appendChild(track);
    row.appendChild(text("span", "wst-bar-value", `${count} avoids`));
    leastVers.appendChild(row);
});

const verRow = make("div", "wst-row");
verRow.appendChild(section("Most Versatile",  mostVers));
