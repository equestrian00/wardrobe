// ═══════════════════════════════════════════════════════════════
//  📋  FORMULA LOADER
// ═══════════════════════════════════════════════════════════════

/**
 * Parse a markdown nested-list note into an OUTFIT_FORMULAS object.
 *
 * Format (any consistent indent — spaces or tabs):
 *
 *   - Formula Name
 *     - slots
 *       - clothingcategory
 *         - clothingsubcategory      ← optional: restrict which subcats appear
 *           - clothingstyle          ← optional: restrict which styles appear
 *     - seasons                      ← optional: restrict to these seasons
 *       - Fall
 *
 * Rules cascade: if subcategories are listed for a slot, only items
 * matching those subcategories appear in that slot. If styles are listed
 * under a subcategory, only items whose clothingstyle matches appear.
 */
function parseListFormulas(text) {
    const items = [];
    for (const line of text.split("\n")) {
        const m = line.match(/^([ \t]*)-[ \t]+(.+)$/);
        if (m) items.push({ depth: m[1].length, val: m[2].trim() });
    }
    if (!items.length) return null;

    // Recursive descent: collect all direct children of a node.
    // All children must have depth > parentDepth.
    // Returns { nodes: [{val, children[]}], nextI }.
    function parseChildren(start, parentDepth) {
        const nodes = [];
        let i = start;
        while (i < items.length && items[i].depth > parentDepth) {
            const childDepth = items[i].depth;
            const node = { val: items[i].val, children: [] };
            i++;
            const sub = parseChildren(i, childDepth);
            node.children = sub.nodes;
            i = sub.nextI;
            nodes.push(node);
            if (i < items.length && items[i].depth < childDepth) break;
        }
        return { nodes, nextI: i };
    }

    const { nodes: formulaNodes } = parseChildren(0, -1);
    const formulas = {};

    for (const fNode of formulaNodes) {
        const name = fNode.val; // preserve original casing for the dropdown
        const slots     = [];
        const seasons   = [];
        const slotRules = {}; // { cat: { subcategories: [], styles: { sub: [] } } }

        for (const section of fNode.children) {
            const key = section.val.toLowerCase();

            if (key === "slots") {
                for (const catNode of section.children) {
                    const cat = catNode.val.toLowerCase();
                    slots.push(cat);

                    if (catNode.children.length) {
                        slotRules[cat] = { subcategories: [], styles: {} };
                        for (const subNode of catNode.children) {
                            const sub = subNode.val.toLowerCase();
                            slotRules[cat].subcategories.push(sub);
                            if (subNode.children.length) {
                                slotRules[cat].styles[sub] =
                                    subNode.children.map(sn => sn.val.toLowerCase());
                            }
                        }
                    }
                }
            } else if (key === "seasons") {
                for (const sNode of section.children) seasons.push(sNode.val);
            }
        }

        if (slots.length) {
            formulas[name] = {
                slots,
                ...(seasons.length              ? { seasons }   : {}),
                ...(Object.keys(slotRules).length ? { slotRules } : {}),
            };
        }
    }

    return Object.keys(formulas).length ? formulas : null;
}

/**
 * Load formulas from the note named CONFIG.formulasNote.
 * Falls back silently to CONFIG.OUTFIT_FORMULAS on any problem.
 */
async function loadFormulas() {
    if (!CONFIG.formulasNote) return CONFIG.OUTFIT_FORMULAS;
    try {
        const file = app.metadataCache.getFirstLinkpathDest(CONFIG.formulasNote, "");
        if (!file) return CONFIG.OUTFIT_FORMULAS;
        const raw    = await app.vault.read(file);
        const parsed = parseListFormulas(raw);
        return parsed || CONFIG.OUTFIT_FORMULAS;
    } catch (e) {
        console.warn("[Wardrobe Stylist] Could not load formulas note:", e);
        return CONFIG.OUTFIT_FORMULAS;
    }
}

// Populated async in bootstrap before first render().
let OUTFIT_FORMULAS = CONFIG.OUTFIT_FORMULAS;

// ═══════════════════════════════════════════════════════════════
//  🛠  UTILITY HELPERS
// ═══════════════════════════════════════════════════════════════

function asList(val) {
    if (!val) return [];
    if (Array.isArray(val)) return val.map(v => String(v).trim()).filter(Boolean);
    return [String(val).trim()].filter(Boolean);
}

function lc(v) { return String(v || "").toLowerCase().trim(); }

/**
 * Read a frontmatter property via a CONFIG.keys alias.
 * This is the only place raw frontmatter names appear in the engine.
 */
function fk(page, alias) { return page[CONFIG.keys[alias]]; }

function toTitleCase(w) {
    return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
}

function cleanStyleField(val) {
    if (!val) return "";
    const parts = Array.isArray(val) ? val : [val];
    return parts
        .flatMap(s => String(s).split(","))
        .map(s => s.trim())
        .filter(Boolean)
        .map(phrase => phrase.split(/\s+/).map(toTitleCase).join(" "))
        .join(" ");
}

function displayName(p) {
    const brand  = fk(p, "brand") ? String(fk(p, "brand")).trim() : "";
    const style  = cleanStyleField(fk(p, "style"));
    const subcat = fk(p, "subcategory")
        ? String(fk(p, "subcategory")).split(/\s+/).map(toTitleCase).join(" ")
        : "";
    return [brand, style, subcat].filter(Boolean).join(" ")
        || p.file.name.replace(/\.md$/, "");
}

function resolveImage(imageProp) {
    if (!imageProp) return null;
    const s = String(imageProp);
    const wm = s.match(/!?\[\[(.+?)(?:\|[^\]]+)?\]\]/);
    if (wm) {
        const name = wm[1];
        const f = app.vault.getFiles().find(
            fi => fi.name === name || fi.path === name ||
                  fi.path.endsWith("/" + name)
        );
        return f ? app.vault.getResourcePath(f) : null;
    }
    if (/^https?:\/\//.test(s)) return s;
    const f2 = app.vault.getAbstractFileByPath(s);
    return f2 ? app.vault.getResourcePath(f2) : null;
}

function linkPaths(val) {
    if (!val) return [];
    const arr = Array.isArray(val) ? val : [val];
    return arr.map(l => {
        if (l && typeof l === "object" && l.path) return l.path;
        const s = String(l);
        const m = s.match(/\[\[(.+?)(?:\|[^\]]+)?\]\]/);
        return m ? m[1] : s;
    }).filter(Boolean);
}

function fileMatchesAny(filePath, paths) {
    const base = filePath.replace(/\.md$/, "");
    return paths.some(p => {
        const pb = p.replace(/\.md$/, "");
        return filePath === p || base === pb ||
               filePath === p + ".md" ||
               filePath.endsWith("/" + p) ||
               filePath.endsWith("/" + p + ".md");
    });
}

function countOverlap(a, b) {
    const bSet = new Set(b.map(lc));
    return a.filter(x => bSet.has(lc(x))).length;
}

function colorTheoryMatch(heroColors, candColors, theory) {
    for (const hc of heroColors) {
        const allowed = (theory[hc] || []).map(lc);
        if (candColors.some(cc => allowed.includes(lc(cc)))) return true;
    }
    return false;
}

// ═══════════════════════════════════════════════════════════════
//  🧠  SCORING ENGINE
// ═══════════════════════════════════════════════════════════════

function scoreCandidate(hero, candidate, wearableOnly) {
    if (candidate.file.path === hero.file.path) return null;

    if (wearableOnly) {
        const s = lc(fk(candidate, "status"));
        if (s === "hamper" || s === "laundry" ||
            s === "donate"  || s === "repair") return null;
    }

    const heroAvoids = linkPaths(fk(hero, "avoids"));
    const candAvoids = linkPaths(fk(candidate, "avoids"));
    if (fileMatchesAny(candidate.file.path, heroAvoids)) return null;
    if (fileMatchesAny(hero.file.path, candAvoids))      return null;

    let score = 0;
    const reasons = [];

    const heroPairs = linkPaths(fk(hero, "pairs"));
    if (fileMatchesAny(candidate.file.path, heroPairs)) {
        score += CONFIG.SCORE.EXPLICIT_PAIR;
        reasons.push(`+${CONFIG.SCORE.EXPLICIT_PAIR} paired`);
    }

    const hColors = asList(fk(hero, "color"));
    const cColors = asList(fk(candidate, "color"));
    if (hColors.length && cColors.length &&
        colorTheoryMatch(hColors, cColors, CONFIG.COLOR_THEORY)) {
        score += CONFIG.SCORE.COLOR_MATCH;
        reasons.push(`+${CONFIG.SCORE.COLOR_MATCH} color`);
    }

    const moodHits = countOverlap(asList(fk(hero, "mood")), asList(fk(candidate, "mood")));
    if (moodHits) {
        const pts = moodHits * CONFIG.SCORE.MOOD_OVERLAP;
        score += pts;
        reasons.push(`+${pts} mood`);
    }

    const occHits = countOverlap(asList(fk(hero, "occasion")), asList(fk(candidate, "occasion")));
    if (occHits) {
        const pts = occHits * CONFIG.SCORE.OCCASION_OVERLAP;
        score += pts;
        reasons.push(`+${pts} occasion`);
    }

    const seasonHits = countOverlap(asList(fk(hero, "season")), asList(fk(candidate, "season")));
    if (seasonHits) {
        const pts = seasonHits * CONFIG.SCORE.SEASON_OVERLAP;
        score += pts;
        reasons.push(`+${pts} season`);
    }

    return { page: candidate, score, reasons };
}

