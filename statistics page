//  🎨  DOM HELPERS
// ═══════════════════════════════════════════════════════════════

function make(tag, cls = "") {
    const el = document.createElement(tag);
    if (cls) el.className = cls;
    return el;
}
function text(tag, cls, content) {
    const el = make(tag, cls);
    el.textContent = content;
    return el;
}

