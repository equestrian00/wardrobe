// ═══════════════════════════════════════════════════════════════
//  🛠  UTILITY HELPERS
// ═══════════════════════════════════════════════════════════════

function asList(val) {
    if (!val) return [];
    if (Array.isArray(val)) return val.map(v => String(v).trim()).filter(Boolean);
    return [String(val).trim()].filter(Boolean);
}

function lc(v) { return String(v || "").toLowerCase().trim(); }

/**
 * Read a frontmatter property from a page using a CONFIG.keys alias.
 * fk(page, "category")  →  page[CONFIG.keys.category]
 * This is the ONLY place raw frontmatter names appear in the engine.
 */
function fk(page, alias) { return page[CONFIG.keys[alias]]; }

function toTitleCase(w) {
    return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
}

/**
 * Flatten a frontmatter value (string or array) into a clean
 * title-cased phrase with no commas.
 * "crew neck,pullover,long sleeve" → "Crew Neck Pullover Long Sleeve"
 */
function cleanStyleField(val) {
    if (!val) return "";
    const parts = Array.isArray(val) ? val : [val];
    return parts
        .flatMap(s => String(s).split(","))
        .map(s => s.trim())
        .filter(Boolean)
        .map(phrase => phrase.split(/\s+/).map(toTitleCase).join(" "))
        .join(" ");
}

/** Display name: "Brand Style Subcategory" */
function displayName(p) {
    const brand  = fk(p, "brand") ? String(fk(p, "brand")).trim() : "";
    const style  = cleanStyleField(fk(p, "style"));
    const subcat = fk(p, "subcategory")
        ? String(fk(p, "subcategory")).split(/\s+/).map(toTitleCase).join(" ")
        : "";
    return [brand, style, subcat].filter(Boolean).join(" ")
        || p.file.name.replace(/\.md$/, "");
}

function resolveImage(imageProp) {
    if (!imageProp) return null;
    const s = String(imageProp);
    const wm = s.match(/!?\[\[(.+?)(?:\|[^\]]+)?\]\]/);
    if (wm) {
        const name = wm[1];
        const f = app.vault.getFiles().find(
            fi => fi.name === name || fi.path === name ||
                  fi.path.endsWith("/" + name)
        );
        return f ? app.vault.getResourcePath(f) : null;
    }
    if (/^https?:\/\//.test(s)) return s;
    const f2 = app.vault.getAbstractFileByPath(s);
    return f2 ? app.vault.getResourcePath(f2) : null;
}

function linkPaths(val) {
    if (!val) return [];
    const arr = Array.isArray(val) ? val : [val];
    return arr.map(l => {
        if (l && typeof l === "object" && l.path) return l.path;
        const s = String(l);
        const m = s.match(/\[\[(.+?)(?:\|[^\]]+)?\]\]/);
        return m ? m[1] : s;
    }).filter(Boolean);
}

function fileMatchesAny(filePath, paths) {
    const base = filePath.replace(/\.md$/, "");
    return paths.some(p => {
        const pb = p.replace(/\.md$/, "");
        return filePath === p || base === pb ||
               filePath === p + ".md" ||
               filePath.endsWith("/" + p) ||
               filePath.endsWith("/" + p + ".md");
    });
}

function countOverlap(a, b) {
    const bSet = new Set(b.map(lc));
    return a.filter(x => bSet.has(lc(x))).length;
}

function colorTheoryMatch(heroColors, candColors, theory) {
    for (const hc of heroColors) {
        const allowed = (theory[hc] || []).map(lc);
        if (candColors.some(cc => allowed.includes(lc(cc)))) return true;
    }
    return false;
}

// ═══════════════════════════════════════════════════════════════
//  🧠  SCORING ENGINE
// ═══════════════════════════════════════════════════════════════

function scoreCandidate(hero, candidate, wearableOnly) {
    if (candidate.file.path === hero.file.path) return null;

    if (wearableOnly) {
        const s = lc(fk(candidate, "status"));
        if (s === "hamper" || s === "laundry" ||
            s === "donate"  || s === "repair") return null;
    }

    const heroAvoids = linkPaths(fk(hero, "avoids"));
    const candAvoids = linkPaths(fk(candidate, "avoids"));
    if (fileMatchesAny(candidate.file.path, heroAvoids)) return null;
    if (fileMatchesAny(hero.file.path, candAvoids))      return null;

    let score = 0;
    const reasons = [];

    const heroPairs = linkPaths(fk(hero, "pairs"));
    if (fileMatchesAny(candidate.file.path, heroPairs)) {
        score += CONFIG.SCORE.EXPLICIT_PAIR;
        reasons.push(`+${CONFIG.SCORE.EXPLICIT_PAIR} paired`);
    }

    const hColors = asList(fk(hero, "color"));
    const cColors = asList(fk(candidate, "color"));
    if (hColors.length && cColors.length &&
        colorTheoryMatch(hColors, cColors, CONFIG.COLOR_THEORY)) {
        score += CONFIG.SCORE.COLOR_MATCH;
        reasons.push(`+${CONFIG.SCORE.COLOR_MATCH} color`);
    }

    const moodHits = countOverlap(asList(fk(hero, "mood")), asList(fk(candidate, "mood")));
    if (moodHits) {
        const pts = moodHits * CONFIG.SCORE.MOOD_OVERLAP;
        score += pts;
        reasons.push(`+${pts} mood`);
    }

    const occHits = countOverlap(asList(fk(hero, "occasion")), asList(fk(candidate, "occasion")));
    if (occHits) {
        const pts = occHits * CONFIG.SCORE.OCCASION_OVERLAP;
        score += pts;
        reasons.push(`+${pts} occasion`);
    }

    const seasonHits = countOverlap(asList(fk(hero, "season")), asList(fk(candidate, "season")));
    if (seasonHits) {
        const pts = seasonHits * CONFIG.SCORE.SEASON_OVERLAP;
        score += pts;
        reasons.push(`+${pts} season`);
    }

    return { page: candidate, score, reasons };
}

// ═══════════════════════════════════════════════════════════════
//  📦  STATE
// ═══════════════════════════════════════════════════════════════

const allPages = dv.pages(`"${CONFIG.itemsFolder}"`).array();

function collectUnique(prop) {
    const s = new Set();
    allPages.forEach(p => asList(p[prop]).forEach(v => v && s.add(v)));
    return [...s].sort();
}

const ALL_SEASONS   = collectUnique(CONFIG.keys.season);
const ALL_MOODS     = collectUnique(CONFIG.keys.mood);
const ALL_OCCASIONS = collectUnique(CONFIG.keys.occasion);

const state = {
    heroPage:       null,
    filterSeason:   [],
    filterMood:     [],
    filterOccasion: [],
    filterFormula:  "Standard",
    wearableOnly:   true,
    debug:          CONFIG.debugDefault,
    slots:          {},
    requiredPaths:  new Set(),
};

// ═══════════════════════════════════════════════════════════════
//  🔁  SUGGESTION ENGINE
// ═══════════════════════════════════════════════════════════════

function updateSuggestions() {
    if (!state.heroPage) { state.slots = {}; return; }

    const formula  = CONFIG.OUTFIT_FORMULAS[state.filterFormula];
    const heroCat  = lc(fk(state.heroPage, "category"));
    const heroSub  = lc(fk(state.heroPage, "subcategory") || "");

    const skipCats = heroCat === "full body" ? ["tops", "bottoms", heroCat] : [heroCat];
    const needed   = formula.slots.filter(s => !skipCats.includes(s));

    state.slots = {};

    needed.forEach(slotCat => {
        let pool = allPages.filter(p => lc(fk(p, "category")) === slotCat);

        if (state.filterSeason.length) {
            const active = state.filterSeason.map(lc);
            pool = pool.filter(p =>
                asList(fk(p, "season")).some(s => active.includes(lc(s))));
        }
        if (state.filterMood.length) {
            const active = state.filterMood.map(lc);
            pool = pool.filter(p =>
                asList(fk(p, "mood")).some(m => active.includes(lc(m))));
        }
        if (state.filterOccasion.length) {
            const active = state.filterOccasion.map(lc);
            pool = pool.filter(p =>
                asList(fk(p, "occasion")).some(o => active.includes(lc(o))));
        }

        if (formula.seasons && formula.seasons.length) {
            const fSeasons = formula.seasons.map(lc);
            pool = pool.filter(p =>
                asList(fk(p, "season")).some(s => fSeasons.includes(lc(s))));
        }

        const subRule = CONFIG.SUBCATEGORY_RULES[heroSub];
        if (subRule && subRule[slotCat]) {
            const preferred = subRule[slotCat].map(lc);
            const prefPool  = pool.filter(p =>
                preferred.includes(lc(fk(p, "subcategory"))));
            if (prefPool.length > 0) pool = prefPool;
        }

        const scored = pool
            .map(p => scoreCandidate(state.heroPage, p, state.wearableOnly))
            .filter(Boolean)
            .sort((a, b) => b.score - a.score);

        state.slots[slotCat] = { candidates: scored, index: 0, locked: false };
    });

    resolveRequires();
}

function resolveRequires() {
    state.requiredPaths = new Set();
    if (!state.heroPage) return;

    Object.values(state.slots).forEach(s => { s.locked = false; });

    const visited = new Set([state.heroPage.file.path]);
    const queue   = [state.heroPage];

    while (queue.length) {
        const page     = queue.shift();
        const reqPaths = linkPaths(fk(page, "requires"));

        for (const rPath of reqPaths) {
            const reqPage = allPages.find(p => fileMatchesAny(p.file.path, [rPath]));
            if (!reqPage || visited.has(reqPage.file.path)) continue;
            visited.add(reqPage.file.path);

            state.requiredPaths.add(reqPage.file.path);
            const cat = lc(fk(reqPage, "category"));

            if (!state.slots[cat]) {
                state.slots[cat] = { candidates: [], index: 0, locked: false };
            }

            const slot = state.slots[cat];
            slot.candidates = slot.candidates.filter(
                c => c.page.file.path !== reqPage.file.path
            );
            slot.candidates.unshift({ page: reqPage, score: 999, reasons: ["required"] });
            slot.index  = 0;
            slot.locked = true;

            queue.push(reqPage);
        }
    }
}

function pickRandomHero() {
    let pool = allPages;
    if (state.wearableOnly) {
        pool = pool.filter(p => {
            const s = lc(fk(p, "status"));
            return s !== "hamper" && s !== "laundry" &&
                   s !== "donate" && s !== "repair";
        });
    }
    if (state.filterSeason.length) {
        const active = state.filterSeason.map(lc);
        pool = pool.filter(p =>
            asList(fk(p, "season")).some(s => active.includes(lc(s))));
    }
    if (state.filterMood.length) {
        const active = state.filterMood.map(lc);
        pool = pool.filter(p =>
            asList(fk(p, "mood")).some(m => active.includes(lc(m))));
    }
    if (state.filterOccasion.length) {
        const active = state.filterOccasion.map(lc);
        pool = pool.filter(p =>
            asList(fk(p, "occasion")).some(o => active.includes(lc(o))));
    }
    if (!pool.length) { showToast("No items match the active filters."); return; }
    state.heroPage = pool[Math.floor(Math.random() * pool.length)];
    updateSuggestions();
}

// ═══════════════════════════════════════════════════════════════
//  📋  LOG OUTFIT
// ═══════════════════════════════════════════════════════════════

async function logOutfit() {
    if (!state.heroPage) return;

    const formula     = CONFIG.OUTFIT_FORMULAS[state.filterFormula];
    const heroCat     = lc(fk(state.heroPage, "category"));
    const skipCats    = heroCat === "full body" ? ["tops", "bottoms", heroCat] : [heroCat];
    const activeSlots = formula.slots.filter(s => !skipCats.includes(s));

    const allSlotCats = [
        ...activeSlots,
        ...Object.keys(state.slots).filter(
            cat => !activeSlots.includes(cat) && !skipCats.includes(cat)
        ),
    ];

    const outfitPages = allSlotCats
        .map(slotCat => {
            const d = state.slots[slotCat];
            if (!d || !d.candidates.length) return null;
            return d.candidates[d.index % d.candidates.length].page;
        })
        .filter(Boolean);

    const today    = new Date().toLocaleDateString("en-CA");
    const allInFit = [state.heroPage, ...outfitPages];

    try {
        for (const page of allInFit) {
            const others = allInFit
                .filter(p => p.file.path !== page.file.path)
                .map(p => `[[${p.file.name.replace(/\.md$/, "")}]]`)
                .join(", ");

            await app.fileManager.processFrontMatter(page.file, fm => {
                fm[CONFIG.keys.wear] = (parseInt(fm[CONFIG.keys.wear]) || 0) + 1;
                if (!fm[CONFIG.keys.outfits])
                    fm[CONFIG.keys.outfits] = [];
                if (!Array.isArray(fm[CONFIG.keys.outfits]))
                    fm[CONFIG.keys.outfits] = [fm[CONFIG.keys.outfits]];
                fm[CONFIG.keys.outfits].push(`${today}: Worn with ${others}`);
            });
        }
        showToast(`Outfit logged — ${allInFit.length} items updated.`);
    } catch (e) {
        showToast(`Could not log outfit: ${e.message}`, true);
        console.error("[Wardrobe Stylist] logOutfit error:", e);
    }
}

