function showToast(msg, isError = false) {
    const t = make("div", "ws-toast" + (isError ? " ws-toast--error" : ""));
    t.textContent = msg;
    ROOT.appendChild(t);
    setTimeout(() => t.classList.add("ws-toast--out"), 2400);
    setTimeout(() => t.remove(), 2800);
}

