// ═══════════════════════════════════════════════════════════════
//  🛠  UTILITIES
// ═══════════════════════════════════════════════════════════════

function fk(p, alias) { return p[CONFIG.keys[alias]]; }
function lc(v) { return String(v || "").toLowerCase().trim(); }
function asList(val) {
    if (!val) return [];
    if (Array.isArray(val)) return val.map(v => String(v).trim()).filter(Boolean);
    return [String(val).trim()].filter(Boolean);
}
function toTitleCase(s) {
    return String(s).replace(/\w\S*/g, w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase());
}
function parseCost(val) {
    if (!val) return 0;
    const n = parseFloat(String(val).replace(/[^0-9.]/g, ""));
    return isNaN(n) ? 0 : n;
}
function fmt$(n) {
    return "$" + n.toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}
function pct(n, total) {
    return total ? Math.round((n / total) * 100) : 0;
}

// Count values in a map, return sorted array [{label, count}]
function tally(pages, keyFn, multi = false) {
    const map = {};
    pages.forEach(p => {
        const vals = multi ? asList(keyFn(p)) : [keyFn(p)];
        vals.forEach(v => {
            const k = String(v || "").trim();
            if (k) map[k] = (map[k] || 0) + 1;
        });
    });
    return Object.entries(map)
        .map(([label, count]) => ({ label, count }))
        .sort((a, b) => b.count - a.count);
}

function linkCount(pages, keyAlias) {
    return pages.map(p => {
        const links = asList(fk(p, keyAlias));
        return { page: p, count: links.length };
    }).sort((a, b) => b.count - a.count);
}

